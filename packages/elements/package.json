{
  "name": "@reglow/elements",
  "version": "0.1.0",
  "description": "Zero-dependency, framework-neutral Web Components for Reglow.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/register.js"
  ],
  "files": [
    "dist",
    "custom-elements.json",
    "README.md",
    "LICENSE"
  ],
  "customElements": "./custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./custom-elements.json": "./custom-elements.json"
  },
  "scripts": {
    "build": "vite build && pnpm generate:custom-elements",
    "generate:custom-elements": "node ./scripts/generate-custom-elements.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3"
  }
}
