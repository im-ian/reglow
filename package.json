{
  "name": "reglow-design-system",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @reglow/tokens build && pnpm --filter @reglow/elements build && pnpm --filter @reglow/react build && pnpm --filter @reglow/preact build && pnpm --filter @reglow/vue build && pnpm --filter @reglow/svelte build && pnpm --filter @reglow/angular build",
    "build:storybook": "storybook build",
    "check": "pnpm typecheck && pnpm test && pnpm build && pnpm test:tree-shaking && pnpm build:storybook",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006 --no-open",
    "test": "vitest run && pnpm --filter @reglow/angular test && pnpm test:examples",
    "test:examples": "node scripts/verify-examples.mjs",
    "test:tree-shaking": "node scripts/verify-tree-shaking.mjs",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/web-components-vite": "^10.5.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "lit": "^3.3.3",
    "lucide-static": "^1.24.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^3.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.0",
    "svelte": "^5.56.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10",
    "vue": "^3.5.39"
  }
}
